# DevCommand release config — copy to .env (gitignored) and fill in. See docs/RELEASING.md.

# Developer ID signing identity — the exact string from:
#   security find-identity -v -p codesigning
SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# --- Notarization: set ONE of the two options below ---

# (a) a stored keychain profile created once with:
#     xcrun notarytool store-credentials devcommand-notary --key ... --key-id ... --issuer ...
NOTARY_PROFILE="devcommand-notary"

# (b) OR a raw App Store Connect API key (reuse the one you already use for TestFlight; ideal for CI):
# ASC_KEY_ID="XXXXXXXXXX"
# ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"

# Optional: auto-bump your Homebrew tap on release (absolute path to the cloned homebrew-tap repo).
# When set, release.sh rewrites Casks/devcommand.rb and pushes it for you.
# HOMEBREW_TAP_DIR="$HOME/Dev/homebrew-tap"

# Optional: override the entitlements file (default: DevCommand.entitlements)
# ENTITLEMENTS="DevCommand.entitlements"
